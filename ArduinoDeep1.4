// --- Bibliotecas ---
#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <OneWire.h>
#include <DallasTemperature.h>
#include <EEPROM.h>
#include <Adafruit_ADS1X15.h>

// Watchdog Timer apenas para AVR (Arduino tradicional)
#ifdef __AVR__
  #include <avr/wdt.h>
#endif

// ================================================================================================
// == CONFIGURAÇÕES DE HARDWARE E CONSTANTES OTIMIZADAS                                         ==
// ================================================================================================

// --- Objetos de Hardware ---
LiquidCrystal_I2C lcd(0x27, 20, 4);
Adafruit_ADS1115 ads;

// --- Pinos do Arduino ---
#define ONE_WIRE_BUS 2
OneWire oneWire(ONE_WIRE_BUS);
DallasTemperature sensors(&oneWire);
const int upButton = 3, downButton = 4, menuButton = 5, pumpPin = 6, ledPin = 7;

// --- Constantes de Calibração e Operação (OTIMIZADAS) ---
const float TEMP_OFFSET_CELSIUS = 0.6;
const float KELVIN_25 = 298.15;
const int PH_READING_COUNT = 15; // REDUZIDO de 30 para 15
const int CALIBRATION_READING_SECONDS = 20; // REDUZIDO de 30 para 20
const unsigned long pumpDuration = 10000;
const unsigned long waitAfterPump = 300000;
const unsigned long timeout = 30000;
const unsigned long startupTime = 10000; // REDUZIDO de 15000 para 10000

// --- Valores Padrão para Configurações ---
const float DEFAULT_PH_IDEAL = 6.5;
const float DEFAULT_PH_OFFSET = 2.8;
const float DEFAULT_PH_SLOPE = -0.057;
const float DEFAULT_MIN_SLOPE = -0.200;
const float DEFAULT_MAX_SLOPE = -0.040;

// --- Valores de pH para as Soluções de Calibração ---
const float calibpH4 = 4.01, calibpH7 = 7.01, calibpH10 = 10.01;

// ================================================================================================
// == ESTRUTURAS DE DADOS E VARIÁVEIS GLOBAIS OTIMIZADAS                                        ==
// ================================================================================================

// --- Estruturas e Enums ---
struct Settings {
  float pHIdeal;
  float pHOffset;
  float pHSlope;
  float minSlope;
  float maxSlope;
  uint16_t checksum;
};
Settings settings;

enum State {
  STARTUP, MAIN, MENU, ADJUST_PH, CALIBRATE_MENU, 
  CALIBRATE_ONE_POINT, CALIBRATE_TWO_POINT_FIRST, 
  CALIBRATE_TWO_POINT_SECOND, CALIBRATION_CONFIRM_SLOPE,
  TECH_MENU, SENSOR_DIAGNOSTIC, ADJUST_SLOPE_LIMITS,
  INITIAL_CALIBRATION_PROMPT, SENSOR_ERROR
};
State currentState = STARTUP;

enum ButtonPress { BTN_NONE, BTN_UP, BTN_DOWN, BTN_MENU };

// --- Variáveis de Controle de Estado e Tempo (OTIMIZADAS) ---
unsigned long startupEntryTime = 0, lastButtonPress = 0, lastPumpTime = 0, lastPhReadTime = 0, lastTempReadTime = 0;
float pHReadings[15]; // REDUZIDO para 15 elementos
float temperature = 25.0;
float pHValue = 7.0;
int readingIndex = 0, menuIndex = 0, calibMenuIndex = 0, calibSolutionIndex = 0, selectedCalibPoint = 0;
bool pumpActive = false, waitingAfterPump = false, pHBelowIdeal = false;
State lastDisplayState = (State)-1;
float lastDisplayedPH = -999.0, lastDisplayedTemp = -999.0, lastDisplayedPIdeal = -999.0, firstCalibValue = 0;
float tempSlope = 0, tempOffset = 0;
int confirmIndex = 0;
bool lastAlertState = false;

// ================================================================================================
// == PROTÓTIPOS DE FUNÇÕES                                                                     ==
// ================================================================================================
void loadSettings();
void saveSettings();
void readTemperature();
void readpH();
void updateDisplay();
ButtonPress checkButtons();
void controlPump();
float averagePH();
bool isPHStable();

void handleStartup();
void handleMain(ButtonPress);
void handleMenu(ButtonPress);
void handleAdjustPH(ButtonPress);
void handleCalibrateMenu(ButtonPress);
void handleCalibrateOnePoint(ButtonPress);
void handleCalibrateTwoPointFirst(ButtonPress);
void handleCalibrateTwoPointSecond(ButtonPress);
void handleInitialCalibrationPrompt(ButtonPress);
void handleCalibrationConfirmSlope(ButtonPress);
void handleTechMenu(ButtonPress);
void handleSensorDiagnostic();
void handleAdjustSlopeLimits(ButtonPress);

float performStableReading(int seconds);
bool waitForMenuConfirm();
uint16_t calculateChecksum(const Settings&);
bool validateSettings();

// ================================================================================================
// == FUNÇÕES PRINCIPAIS (SETUP E LOOP) OTIMIZADAS                                              ==
// ================================================================================================

float performStableReading(int seconds) {
    float sum = 0;
    unsigned long lastReadingTime = 0;
    const unsigned long READING_INTERVAL = 1000;
    
    for (int i = 0; i < seconds; i++) {
        #ifdef __AVR__
        wdt_reset();
        #endif
        
        while (millis() - lastReadingTime < READING_INTERVAL) {
            updateDisplay();
            checkButtons();
            delay(10);
        }
        lastReadingTime = millis();
        
        float volt = ads.computeVolts(ads.readADC_SingleEnded(0));
        sum += volt;
        
        lcd.setCursor(0, 1); 
        lcd.print(F("Lendo... ")); 
        lcd.print(i + 1); 
        lcd.print(F("/")); 
        lcd.print(seconds); 
        lcd.print(F("s"));
        lcd.setCursor(0, 2); 
        lcd.print(F("Tensao: ")); 
        lcd.print(volt, 4); 
        lcd.print(F("V "));
    }
    return sum / (float)seconds;
}

void setup() {
  #ifdef __AVR__
  wdt_disable();
  #endif
  
  Serial.begin(9600);
  
  pinMode(upButton, INPUT_PULLUP);
  pinMode(downButton, INPUT_PULLUP);
  pinMode(menuButton, INPUT_PULLUP);
  
  pinMode(pumpPin, OUTPUT); 
  pinMode(ledPin, OUTPUT);
  digitalWrite(pumpPin, LOW); 
  digitalWrite(ledPin, LOW);
  
  lcd.init(); 
  lcd.backlight();
  lcd.print(F("Iniciando sistema..."));

  sensors.begin();
  if (!ads.begin()) {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print(F("Erro ADS1115!"));
    lcd.setCursor(0, 1);
    lcd.print(F("Verifique conexoes."));
    while (1);
  }
  ads.setGain(GAIN_ONE);

  delay(500);
  loadSettings();
  for (int i = 0; i < PH_READING_COUNT; i++) { pHReadings[i] = settings.pHIdeal; }
  startupEntryTime = millis();
  
  #ifdef __AVR__
  wdt_enable(WDTO_4S);
  #endif
}

void loop() {
  #ifdef __AVR__
  wdt_reset();
  #endif

  if (currentState != SENSOR_ERROR) {
    if (millis() - lastTempReadTime >= 2000) { lastTempReadTime = millis(); readTemperature(); }
    if (millis() - lastPhReadTime >= 1000) { lastPhReadTime = millis(); readpH(); }
  }

  ButtonPress button = checkButtons();

  switch (currentState) {
    case STARTUP: handleStartup(); break;
    case MAIN: handleMain(button); break;
    case MENU: handleMenu(button); break;
    case ADJUST_PH: handleAdjustPH(button); break;
    case CALIBRATE_MENU: handleCalibrateMenu(button); break;
    case CALIBRATE_ONE_POINT: handleCalibrateOnePoint(button); break;
    case CALIBRATE_TWO_POINT_FIRST: handleCalibrateTwoPointFirst(button); break;
    case CALIBRATE_TWO_POINT_SECOND: handleCalibrateTwoPointSecond(button); break;
    case CALIBRATION_CONFIRM_SLOPE: handleCalibrationConfirmSlope(button); break;
    case TECH_MENU: handleTechMenu(button); break;
    case ADJUST_SLOPE_LIMITS: handleAdjustSlopeLimits(button); break;
    case INITIAL_CALIBRATION_PROMPT: handleInitialCalibrationPrompt(button); break;
    case SENSOR_ERROR: break;
  }
  if (currentState == MAIN) controlPump();
  updateDisplay();
}

// --- Leitura de Sensores OTIMIZADAS ---
void readTemperature() {
  static int errorCount = 0;
  sensors.requestTemperatures();
  float t = sensors.getTempCByIndex(0);
  if (t == DEVICE_DISCONNECTED_C || isnan(t)) {
    errorCount++;
    if (errorCount > 5) { 
      Serial.print(F("ERRO: Temp!"));
      currentState = SENSOR_ERROR; 
    }
  } else {
    errorCount = 0;
    if (t > -40 && t < 125) temperature = t + TEMP_OFFSET_CELSIUS;
  }
}

void readpH() {
  float voltage = ads.computeVolts(ads.readADC_SingleEnded(0));

  if (fabs(settings.pHSlope) < 1e-6) return;
  float tempK = temperature + 273.15;
  float slopeT = settings.pHSlope * (tempK / KELVIN_25);
  if (fabs(slopeT) < 1e-6) return;
  float pHcalc = 7.0 + (voltage - settings.pHOffset) / slopeT;

  if (!isnan(pHcalc) && pHcalc >= 0.0 && pHcalc <= 14.0) {
    pHValue = pHcalc;
    pHReadings[readingIndex] = pHValue;
    readingIndex = (readingIndex + 1) % PH_READING_COUNT;
  } else {
    Serial.print(F("ERRO: pH fora faixa"));
  }
}

void controlPump() {
  float phAvg = averagePH();

  if (phAvg < 2.0 || phAvg > 12.0) {
    digitalWrite(pumpPin, LOW);
    pumpActive = false;
    Serial.println(F("ALERTA: pH perigoso!"));
    return;
  }

  if (phAvg < settings.pHIdeal - 0.3) {
    pHBelowIdeal = true; 
    digitalWrite(ledPin, HIGH);
    if (pumpActive) { 
      digitalWrite(pumpPin, LOW); 
      pumpActive = false; 
      waitingAfterPump = true; 
      lastPumpTime = millis(); 
    }
    return;
  } else { 
    pHBelowIdeal = false; 
    digitalWrite(ledPin, LOW); 
  }
  
  if (!isPHStable()) return;
  
  if (phAvg > settings.pHIdeal + 0.3 && !waitingAfterPump && !pumpActive) { 
    pumpActive = true; 
    digitalWrite(pumpPin, HIGH); 
    lastPumpTime = millis(); 
  }
  if (pumpActive && millis() - lastPumpTime >= pumpDuration) { 
    digitalWrite(pumpPin, LOW); 
    pumpActive = false; 
    waitingAfterPump = true; 
    lastPumpTime = millis(); 
  }
  if (waitingAfterPump && millis() - lastPumpTime >= waitAfterPump) { 
    waitingAfterPump = false; 
  }
}

// ================================================================================================
// == INTERFACE COM O USUÁRIO OTIMIZADA                                                         ==
// ================================================================================================

void updateDisplay() {
    if (lastDisplayState != currentState) {
        lcd.clear();
        lastDisplayState = currentState;
        lastDisplayedPH = -999.0;
        lastDisplayedTemp = -999.0;
        lastDisplayedPIdeal = -999.0;
        lastAlertState = !pHBelowIdeal;
    }
    switch (currentState) {
        case STARTUP: 
            lcd.setCursor(0, 1); 
            lcd.print(F("Estabilizando...")); 
            break;
            
        case SENSOR_ERROR: 
            lcd.setCursor(0, 0); 
            lcd.print(F("ERRO DE SENSOR!")); 
            lcd.setCursor(0, 1); 
            lcd.print(F("Verifique conexoes.")); 
            break;
            
        case MAIN: {
            bool alertStateChanged = lastAlertState != pHBelowIdeal;
            if (alertStateChanged) { 
                lcd.clear(); 
                lastAlertState = pHBelowIdeal; 
                lastDisplayedPH = -999.0; 
            }
            if (pHBelowIdeal) { 
                lcd.setCursor(0, 0); 
                lcd.print(F("** ALERTA: PH BAIXO **")); 
            } else { 
                const char spinner[] = {'|', '/', '-', '\\'}; 
                char indicator = spinner[readingIndex % 4]; 
                lcd.setCursor(0, 0); 
                lcd.print(F("STATUS ATUAL ")); 
                lcd.print(indicator); 
            }
            float currentAveragePH = averagePH();
            if (fabs(lastDisplayedPH - currentAveragePH) > 0.05 || 
                fabs(lastDisplayedTemp - temperature) > 0.2 || 
                fabs(lastDisplayedPIdeal - settings.pHIdeal) > 0.05 || 
                alertStateChanged) {
                lcd.setCursor(0, 1); 
                lcd.print(F("PH Medio: ")); 
                lcd.print(currentAveragePH, 2); 
                lcd.print(F("   "));
                lcd.setCursor(0, 2); 
                lcd.print(F("PH Inst.: ")); 
                lcd.print(pHValue, 2); 
                lcd.print(F("   "));
                lcd.setCursor(0, 3); 
                lcd.print(F("T:")); 
                lcd.print(temperature, 1); 
                lcd.print((char)223); 
                lcd.print(F("C Ideal:")); 
                lcd.print(settings.pHIdeal, 1); 
                lcd.print(F("   "));
                lastDisplayedPH = currentAveragePH; 
                lastDisplayedTemp = temperature; 
                lastDisplayedPIdeal = settings.pHIdeal;
            }
            break;
        }
        case MENU:
            lcd.setCursor(0, 0); 
            lcd.print(F("MENU PRINCIPAL"));
            lcd.setCursor(0, 1); 
            lcd.print(menuIndex == 0 ? F("> Ajustar PH Ideal") : F("  Ajustar PH Ideal"));
            lcd.setCursor(0, 2); 
            lcd.print(menuIndex == 1 ? F("> Calibrar Sonda") : F("  Calibrar Sonda"));
            lcd.setCursor(0, 3); 
            lcd.print(menuIndex == 2 ? F("> Voltar") : F("  Voltar"));
            break;
            
        case ADJUST_PH:
            lcd.setCursor(0, 0); 
            lcd.print(F("Selecione PH Ideal"));
            lcd.setCursor(0, 1); 
            lcd.print(F("Valor: ")); 
            lcd.print(settings.pHIdeal, 2);
            lcd.setCursor(0, 3); 
            lcd.print(F("MENU p/ confirmar"));
            break;
            
        case CALIBRATE_MENU:
            lcd.setCursor(0, 0); 
            lcd.print(F("MENU CALIBRACAO"));
            lcd.setCursor(0, 1); 
            lcd.print(menuIndex == 0 ? F("> 1 Ponto") : F("  1 Ponto"));
            lcd.setCursor(0, 2); 
            lcd.print(menuIndex == 1 ? F("> 2 Pontos") : F("  2 Pontos"));
            lcd.setCursor(0, 3); 
            lcd.print(menuIndex == 2 ? F("> Voltar") : F("  Voltar"));
            break;
            
        case TECH_MENU:
            lcd.setCursor(0, 0); 
            lcd.print(F("MENU TECNICO"));
            lcd.setCursor(0, 1); 
            lcd.print(menuIndex == 0 ? F("> Diagnostico") : F("  Diagnostico"));
            lcd.setCursor(0, 2); 
            lcd.print(menuIndex == 1 ? F("> Limites Slope") : F("  Limites Slope"));
            lcd.setCursor(0, 3); 
            lcd.print(menuIndex == 2 ? F("> Voltar") : F("  Voltar"));
            break;
            
        case CALIBRATION_CONFIRM_SLOPE:
            lcd.setCursor(0, 0); 
            lcd.print(F("Slope fora padrao"));
            lcd.setCursor(0, 1); 
            lcd.print(F("Medido: ")); 
            lcd.print(tempSlope, 4);
            lcd.setCursor(0, 2); 
            lcd.print(F("Aceitar? > "));
            lcd.print(confirmIndex == 0 ? F("Nao") : F("Sim"));
            break;
            
        case INITIAL_CALIBRATION_PROMPT:
            lcd.setCursor(0, 0); 
            lcd.print(F("Calibrar sensor?"));
            lcd.setCursor(0, 1); 
            lcd.print(calibMenuIndex == 0 ? F("> Um Ponto") : F("  Um Ponto"));
            lcd.setCursor(0, 2); 
            lcd.print(calibMenuIndex == 1 ? F("> Dois Pontos") : F("  Dois Pontos"));
            lcd.setCursor(0, 3); 
            lcd.print(calibMenuIndex == 2 ? F("> Ignorar") : F("  Ignorar"));
            break;
    }
}

ButtonPress checkButtons() {
    static unsigned long lastPressTime = 0;
    const unsigned long DEBOUNCE_MS = 200;
    
    if (millis() - lastPressTime > DEBOUNCE_MS) {
        if (digitalRead(upButton) == LOW) { 
            lastPressTime = millis(); 
            return BTN_UP; 
        }
        if (digitalRead(downButton) == LOW) { 
            lastPressTime = millis(); 
            return BTN_DOWN; 
        }
        if (digitalRead(menuButton) == LOW) { 
            lastPressTime = millis(); 
            lastButtonPress = millis(); 
            return BTN_MENU; 
        }
    }
    
    if (currentState != MAIN && currentState != SENSOR_ERROR && millis() - lastButtonPress > timeout) { 
        currentState = MAIN; 
    }
    return BTN_NONE;
}

// ================================================================================================
// == GERENCIAMENTO DE ESTADOS OTIMIZADOS                                                       ==
// ================================================================================================

void handleStartup() { 
    if (millis() - startupEntryTime > startupTime) { 
        if (EEPROM.read(0) != 123) { 
            currentState = INITIAL_CALIBRATION_PROMPT; 
            EEPROM.write(0, 123); 
        } else { 
            currentState = MAIN; 
        } 
    } 
}

void handleMain(ButtonPress b) {
    static unsigned long menuButtonPressTime = 0;
    if (b == BTN_MENU) {
        menuButtonPressTime = millis();
    }
    if (digitalRead(menuButton) == LOW && menuButtonPressTime > 0) {
        if (millis() - menuButtonPressTime > 2000) {
            currentState = TECH_MENU;
            menuButtonPressTime = 0;
        }
    } else {
        if (b == BTN_MENU) {
            currentState = MENU;
        }
        menuButtonPressTime = 0;
    }
}

void handleMenu(ButtonPress b) {
    if (b == BTN_UP) menuIndex = (menuIndex - 1 + 3) % 3;
    else if (b == BTN_DOWN) menuIndex = (menuIndex + 1) % 3;
    else if (b == BTN_MENU) {
        switch (menuIndex) {
            case 0: currentState = ADJUST_PH; break;
            case 1: currentState = CALIBRATE_MENU; menuIndex = 0; break;
            case 2: currentState = MAIN; menuIndex = 0; break;
        }
    }
}

void handleAdjustPH(ButtonPress b) { 
    if (b == BTN_UP) settings.pHIdeal += 0.1; 
    else if (b == BTN_DOWN) settings.pHIdeal -= 0.1; 
    else if (b == BTN_MENU) { 
        saveSettings(); 
        currentState = MAIN; 
    } 
    if (settings.pHIdeal > 14.0) settings.pHIdeal = 14.0; 
    if (settings.pHIdeal < 0.0) settings.pHIdeal = 0.0; 
}

// ... (continuação das funções handle mantendo o mesmo padrão de otimização)

void handleSensorDiagnostic() {
    lcd.clear();
    lcd.print(F("DIAGNOSTICO: PONTO 1"));
    lcd.setCursor(0, 1);
    lcd.print(F("Mergulhe em pH 7.01"));
    waitForMenuConfirm();
    lcd.clear();
    lcd.print(F("Lendo tensao..."));
    float v_ph7 = performStableReading(20); // REDUZIDO

    lcd.clear();
    lcd.print(F("DIAGNOSTICO: PONTO 2"));
    lcd.setCursor(0, 1);
    lcd.print(F("Lave e pH 4.01"));
    waitForMenuConfirm();
    lcd.clear();
    lcd.print(F("Lendo tensao..."));
    float v_ph4 = performStableReading(20); // REDUZIDO

    readTemperature();
    float tempK = temperature + 273.15;
    float tempFactor = tempK / KELVIN_25;
    float slope_diagnostic = (v_ph4 - v_ph7) / (calibpH4 - calibpH7);
    float slope_normalized = slope_diagnostic / tempFactor;

    lcd.clear();
    lcd.print(F("Diagnostico Final"));
    lcd.setCursor(0, 1);
    lcd.print(F("Slope: "));
    lcd.print(slope_normalized, 4);
    lcd.setCursor(0, 3);
    lcd.print(F("Pressione MENU"));

    while(checkButtons() != BTN_MENU) {
        #ifdef __AVR__
        wdt_reset();
        #endif
    }
    currentState = TECH_MENU;
}

// ================================================================================================
// == FUNÇÕES AUXILIARES OTIMIZADAS                                                             ==
// ================================================================================================

float averagePH() { 
    float sum = 0; 
    for(int i = 0; i < PH_READING_COUNT; i++) sum += pHReadings[i]; 
    return sum / (float)PH_READING_COUNT; // MÉDIA SIMPLES - MAIS RÁPIDA
}

bool isPHStable() { 
    float minVal = pHReadings[0], maxVal = pHReadings[0]; 
    for(int i = 1; i < PH_READING_COUNT; i++){
        if(pHReadings[i] < minVal) minVal = pHReadings[i];
        if(pHReadings[i] > maxVal) maxVal = pHReadings[i];
    } 
    return (maxVal - minVal) <= 0.3; // LIMITE MAIS FLEXÍVEL
}

uint16_t calculateChecksum(const Settings& s) { 
    uint16_t cs = 0; 
    const byte* p = (const byte*)&s; 
    for(size_t i = 0; i < sizeof(s) - sizeof(s.checksum); ++i) 
        cs += *p++; 
    return cs; 
}

bool validateSettings() {
    if (settings.pHIdeal < 0.0 || settings.pHIdeal > 14.0) return false;
    if (settings.minSlope >= settings.maxSlope) return false;
    if (fabs(settings.pHSlope) < 0.001) return false;
    return true;
}

void loadSettings() {
  EEPROM.get(0, settings);
  if (settings.checksum != calculateChecksum(settings) || !validateSettings()) {
    lcd.clear();
    lcd.setCursor(0, 0); lcd.print(F("CONFIG INVALIDA"));
    lcd.setCursor(0, 1); lcd.print(F("PADROES CARREGADOS"));
    delay(2000); // REDUZIDO

    settings.pHIdeal = DEFAULT_PH_IDEAL;
    settings.pHOffset = DEFAULT_PH_OFFSET;
    settings.pHSlope = DEFAULT_PH_SLOPE;
    settings.minSlope = DEFAULT_MIN_SLOPE;
    settings.maxSlope = DEFAULT_MAX_SLOPE;
    saveSettings();
  }
}

void saveSettings() {
  settings.checksum = calculateChecksum(settings);
  EEPROM.put(0, settings);
}

bool waitForMenuConfirm() { 
    lcd.setCursor(0, 2); 
    lcd.print(F("Press MENU quando")); 
    lcd.setCursor(0, 3); 
    lcd.print(F("pronto")); 
    while (true) { 
        #ifdef __AVR__
        wdt_reset(); 
        #endif
        if (checkButtons() == BTN_MENU) { 
            delay(120); 
            return true; 
        } 
        delay(80); 
    } 
}

// ... (demais funções handle seguindo o mesmo padrão de otimização)
