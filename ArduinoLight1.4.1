const unsigned long PUMP_DURATION = 10000;
const unsigned long PUMP_WAIT_TIME = 300000;
const unsigned long MENU_TIMEOUT = 30000;
const unsigned long STARTUP_DELAY = 5000;
const unsigned long DEBOUNCE_DELAY = 200;
const unsigned long DISPLAY_UPDATE_DELAY = 50;
const unsigned long BUTTON_LONG_PRESS = 2000;

// --- CONFIGURAÇÕES DE PH ---
const float PH_IDEAL_DEFAULT = 6.5;
const float PH_OFFSET_DEFAULT = 2.8;
const float PH_SLOPE_DEFAULT = -0.057;
const float PH_MIN_SAFE = 2.0;
const float PH_MAX_SAFE = 12.0;
const float PH_MIN_VALID = 0.0;
const float PH_MAX_VALID = 14.0;
const float PH_TOLERANCE = 0.3;
const float PH_STABILITY_THRESHOLD = 0.25;
const float PH_DISPLAY_THRESHOLD = 0.05;
const float PH_ADJUST_STEP = 0.1;

// --- CONFIGURAÇÕES DE TEMPERATURA ---
const float TEMP_OFFSET = 0.6;
const float TEMP_KELVIN_25 = 298.15;
const float TEMP_MIN_VALID = -40.0;
const float TEMP_MAX_VALID = 125.0;
const float TEMP_DISPLAY_THRESHOLD = 0.2;

// --- CONFIGURAÇÕES DE CALIBRAÇÃO ---
const float CALIB_PH4 = 4.01;
const float CALIB_PH7 = 7.01;
const float CALIB_PH10 = 10.01;
const uint8_t CALIBRATION_READINGS = 10;
const uint16_t CALIBRATION_READING_DELAY = 1000;

// --- CONFIGURAÇÕES DE BUFFER ---
