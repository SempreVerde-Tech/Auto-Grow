// == FUNÇÕES AUXILIARES                                                                        ==
// ================================================================================================

float performStableReading(uint8_t seconds) {
  float sum = 0;
  unsigned long lastReadingTime = 0;
  
  for (uint8_t i = 0; i < seconds; i++) {
    #ifdef __AVR__
    wdt_reset();
    #endif
    
    // Aguarda intervalo entre leituras
    while (millis() - lastReadingTime < CALIBRATION_READING_DELAY) {
      updateDisplay();
      checkButtons();
      delay(10);
    }
    lastReadingTime = millis();
    
    float voltage = ads.computeVolts(ads.readADC_SingleEnded(0));
    sum += voltage;
    
    // Mostra progresso
    lcd.setCursor(0, 1);
    lcd.print("Lendo... ");
    lcd.print(i + 1);
    lcd.print("/");
    lcd.print(seconds);
    lcd.print("s");
  }
  
  return sum / seconds;
}

bool waitForMenuConfirm() {
  lcd.setCursor(0, 2);
  lcd.print("Pressione MENU");
  lcd.setCursor(0, 3);
  lcd.print("quando pronto");
  
  unsigned long startTime = millis();
  
  while (millis() - startTime < 30000) { // Timeout de 30 segundos
    #ifdef __AVR__
    wdt_reset();
    #endif
    
    ButtonPress btn = checkButtons();
    if (btn == BTN_MENU) {
      delay(200); // Debounce adicional
      return true;
    }
    delay(100);
  }
  
  return false; // Timeout
}

uint16_t calculateChecksum(const Settings& s) {
  uint16_t checksum = 0;
  const uint8_t* data = (const uint8_t*)&s;
  
  for (size_t i = 0; i < sizeof(Settings) - sizeof(s.checksum); i++) {
    checksum += data[i];
  }
  
  return checksum;
}

bool validateSettings() {
  if (settings.pHIdeal < PH_MIN_VALID || settings.pHIdeal > PH_MAX_VALID) return false;
  if (settings.minSlope >= settings.maxSlope) return false;
  if (fabs(settings.pHSlope) < 0.001) return false;
  if (settings.pHOffset < 0.0 || settings.pHOffset > 5.0) return false;
  return true;
}

void loadSettings() {
  EEPROM.get(EEPROM_CONFIG_ADDRESS, settings);
  
  if (settings.checksum != calculateChecksum(settings) || !validateSettings()) {
    // Carrega valores padrão
    lcd.clear();
    lcd.print("Config. invalida");
    lcd.setCursor(0, 1);
    lcd.print("Carregando padroes");
    delay(2000);
    
    settings.pHIdeal = PH_IDEAL_DEFAULT;
    settings.pHOffset = PH_OFFSET_DEFAULT;
    settings.pHSlope = PH_SLOPE_DEFAULT;
    settings.minSlope = -0.200;
    settings.maxSlope = -0.040;
    
    saveSettings();
  }
}

void saveSettings() {
  settings.checksum = calculateChecksum(settings);
  EEPROM.put(EEPROM_CONFIG_ADDRESS, settings);
}
