  float pHIdeal;
  float pHOffset;
  float pHSlope;
  float minSlope;
  float maxSlope;
  uint16_t checksum;
};
Settings settings;

enum SystemState {
  STATE_STARTUP,
  STATE_MAIN,
  STATE_MENU,
  STATE_ADJUST_PH,
  STATE_CALIBRATE_MENU,
  STATE_CALIBRATE_ONE_POINT,
  STATE_CALIBRATE_TWO_POINT_FIRST,
  STATE_CALIBRATE_TWO_POINT_SECOND,
  STATE_CALIBRATION_CONFIRM,
  STATE_ERROR
};

enum ButtonPress {
  BTN_NONE,
  BTN_UP,
  BTN_DOWN,
  BTN_MENU
};

// --- VARIÁVEIS DE ESTADO ---
SystemState currentState = STATE_STARTUP;
SystemState lastDisplayState = STATE_STARTUP;

float pHReadings[PH_BUFFER_SIZE];
float temperature = 25.0;
float currentPH = 7.0;
uint8_t readingIndex = 0;
uint8_t menuIndex = 0;
uint8_t calibMenuIndex = 0;
uint8_t calibSolutionIndex = 0;
uint8_t selectedCalibPoint = 0;

bool pumpActive = false;
bool waitingAfterPump = false;
bool pHBelowIdeal = false;
bool lastAlertState = false;

unsigned long startupTime = 0;
unsigned long lastButtonPress = 0;
unsigned long lastPumpTime = 0;
unsigned long lastTempReadTime = 0;
unsigned long lastPHReadTime = 0;

float lastDisplayedPH = -999.0;
float lastDisplayedTemp = -999.0;
float lastDisplayedIdeal = -999.0;
float firstCalibValue = 0;
float tempSlope = 0;
float tempOffset = 0;
uint8_t confirmIndex = 0;

