void handleCalibrationConfirm(ButtonPress b) {
  if (b == BTN_UP || b == BTN_DOWN) {
    confirmIndex = !confirmIndex;
    lastButtonPress = millis();
  } else if (b == BTN_MENU) {
    if (confirmIndex == 1) {
      // Aceita calibração
      settings.pHSlope = tempSlope;
      settings.pHOffset = tempOffset;
      saveSettings();
      lcd.clear();
      lcd.print("Calibracao salva!");
      delay(1500);
    } else {
      lcd.clear();
      lcd.print("Calibracao");
      lcd.setCursor(0, 1);
      lcd.print("cancelada");
      delay(1500);
    }
    currentState = STATE_MAIN;
    confirmIndex = 0;
    menuIndex = 0;
  }
}

