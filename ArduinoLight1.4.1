// ================================================================================================
// == CONFIGURAÇÃO INICIAL                                                                      ==
// ================================================================================================

void setup() {
  #ifdef __AVR__
  wdt_disable();
  #endif
  
  Serial.begin(9600);
  
  // Configuração dos pinos
  pinMode(BUTTON_UP_PIN, INPUT_PULLUP);
  pinMode(BUTTON_DOWN_PIN, INPUT_PULLUP);
  pinMode(BUTTON_MENU_PIN, INPUT_PULLUP);
  pinMode(PUMP_PIN, OUTPUT);
  pinMode(LED_PIN, OUTPUT);
  digitalWrite(PUMP_PIN, LOW);
  digitalWrite(LED_PIN, LOW);
  
  // Inicialização do LCD
  lcd.init();
  lcd.backlight();
  lcd.print("Iniciando sistema...");
  
  // Inicialização dos sensores
  sensors.begin();
  if (!ads.begin()) {
    lcd.clear();
    lcd.print("Erro ADS1115!");
    lcd.setCursor(0, 1);
    lcd.print("Verifique conexoes");
    while (true) {
      delay(1000);
    }
  }
  ads.setGain(GAIN_ONE);
  
  // Carrega configurações
  loadSettings();
  
  // Inicializa buffer de pH
  for (uint8_t i = 0; i < PH_BUFFER_SIZE; i++) {
    pHReadings[i] = settings.pHIdeal;
  }
  
  startupTime = millis();
  
  #ifdef __AVR__
  wdt_enable(WDTO_4S);
  #endif
}

// ================================================================================================
// == LOOP PRINCIPAL                                                                            ==
// ================================================================================================

void loop() {
  #ifdef __AVR__
  wdt_reset();
  #endif
  
  // Leitura de sensores (exceto em estado de erro)
  if (currentState != STATE_ERROR) {
    unsigned long currentTime = millis();
    
    if (currentTime - lastTempReadTime >= TEMP_READ_INTERVAL) {
      lastTempReadTime = currentTime;
      readTemperature();
    }
    
    if (currentTime - lastPHReadTime >= PH_READ_INTERVAL) {
      lastPHReadTime = currentTime;
      readPH();
    }
  }
  
  // Processa botões
  ButtonPress button = checkButtons();
  
  // Máquina de estados
  switch (currentState) {
    case STATE_STARTUP:
      handleStartup();
      break;
    case STATE_MAIN:
      handleMain(button);
      break;
    case STATE_MENU:
      handleMenu(button);
      break;
    case STATE_ADJUST_PH:
      handleAdjustPH(button);
      break;
    case STATE_CALIBRATE_MENU:
      handleCalibrateMenu(button);
      break;
    case STATE_CALIBRATE_ONE_POINT:
      handleCalibrateOnePoint(button);
      break;
    case STATE_CALIBRATE_TWO_POINT_FIRST:
      handleCalibrateTwoPointFirst(button);
      break;
    case STATE_CALIBRATE_TWO_POINT_SECOND:
      handleCalibrateTwoPointSecond(button);
      break;
    case STATE_CALIBRATION_CONFIRM:
      handleCalibrationConfirm(button);
      break;
    case STATE_ERROR:
      // Aguarda reset manual
      break;
  }
  
  // Controle da bomba apenas no estado principal
  if (currentState == STATE_MAIN) {
    controlPump();
  }
  
  // Atualiza display
  updateDisplay();
  
  delay(DISPLAY_UPDATE_DELAY);
}

// ================================================================================================
// == FUNÇÕES DE SENSORES E CONTROLE                                                            ==
// ================================================================================================

void readTemperature() {
  static uint8_t errorCount = 0;
  
  sensors.requestTemperatures();
  float temp = sensors.getTempCByIndex(0);
  
  if (temp == DEVICE_DISCONNECTED_C || isnan(temp)) {
    errorCount++;
    if (errorCount > 5) {
      currentState = STATE_ERROR;
    }
  } else {
    errorCount = 0;
    if (temp > TEMP_MIN_VALID && temp < TEMP_MAX_VALID) {
      temperature = temp + TEMP_OFFSET;
    }
  }
}

void readPH() {
  int16_t adcValue = ads.readADC_SingleEnded(0);
  float voltage = ads.computeVolts(adcValue);
  
  // Verifica leitura válida do ADS1115
  if (adcValue == 0 || adcValue == 32767) {
    return;
  }
  
  // Verifica slope válido
  if (fabs(settings.pHSlope) < 0.001) {
    return;
  }
  
  // Compensação por temperatura
  float tempKelvin = temperature + 273.15;
  float compensatedSlope = settings.pHSlope * (tempKelvin / TEMP_KELVIN_25);
  
  if (fabs(compensatedSlope) < 0.001) {
    return;
  }
  
  // Calcula pH
  float calculatedPH = 7.0 + (voltage - settings.pHOffset) / compensatedSlope;
  
  // Valida resultado
  if (!isnan(calculatedPH) && calculatedPH >= PH_MIN_VALID && calculatedPH <= PH_MAX_VALID) {
    currentPH = calculatedPH;
    pHReadings[readingIndex] = currentPH;
    readingIndex = (readingIndex + 1) % PH_BUFFER_SIZE;
  }
}

float getAveragePH() {
  float sum = 0;
  uint8_t validReadings = 0;
  
  for (uint8_t i = 0; i < PH_BUFFER_SIZE; i++) {
    if (pHReadings[i] >= PH_MIN_VALID && pHReadings[i] <= PH_MAX_VALID) {
      sum += pHReadings[i];
      validReadings++;
    }
  }
  
  if (validReadings > 0) {
    return sum / validReadings;
  } else {
    return 7.0; // Valor padrão se não houver leituras válidas
  }
}

bool isPHStable() {
  float minValue = PH_MAX_VALID;
  float maxValue = PH_MIN_VALID;
  uint8_t validReadings = 0;
  
  for (uint8_t i = 0; i < PH_BUFFER_SIZE; i++) {
    if (pHReadings[i] >= PH_MIN_VALID && pHReadings[i] <= PH_MAX_VALID) {
      if (pHReadings[i] < minValue) minValue = pHReadings[i];
      if (pHReadings[i] > maxValue) maxValue = pHReadings[i];
      validReadings++;
    }
  }
  
  if (validReadings < PH_BUFFER_SIZE / 2) {
    return false; // Não há leituras suficientes
  }
  
  return (maxValue - minValue) <= PH_STABILITY_THRESHOLD;
}

void controlPump() {
  float averagePH = getAveragePH();
  
  // Segurança: desliga bomba em pH perigoso
  if (averagePH < PH_MIN_SAFE || averagePH > PH_MAX_SAFE) {
    digitalWrite(PUMP_PIN, LOW);
    pumpActive = false;
    return;
  }
  
  // Detecta pH baixo (alerta)
  if (averagePH < settings.pHIdeal - PH_TOLERANCE) {
    pHBelowIdeal = true;
    digitalWrite(LED_PIN, HIGH);
    
    if (pumpActive) {
      digitalWrite(PUMP_PIN, LOW);
      pumpActive = false;
      waitingAfterPump = true;
      lastPumpTime = millis();
    }
    return;
  } else {
    pHBelowIdeal = false;
    digitalWrite(LED_PIN, LOW);
  }
  
  // Aguarda estabilização do pH
  if (!isPHStable()) {
    return;
  }
  
  // Ativa bomba se pH estiver alto
  if (averagePH > settings.pHIdeal + PH_TOLERANCE && !waitingAfterPump && !pumpActive) {
    pumpActive = true;
    digitalWrite(PUMP_PIN, HIGH);
    lastPumpTime = millis();
  }
  
  // Desliga bomba após tempo determinado
  if (pumpActive && millis() - lastPumpTime >= PUMP_DURATION) {
    digitalWrite(PUMP_PIN, LOW);
    pumpActive = false;
    waitingAfterPump = true;
    lastPumpTime = millis();
  }
  
  // Libera bomba após tempo de espera
  if (waitingAfterPump && millis() - lastPumpTime >= PUMP_WAIT_TIME) {
    waitingAfterPump = false;
  }
}

// ================================================================================================
// == FUNÇÕES DE INTERFACE DO USUÁRIO                                                           ==
// ================================================================================================

ButtonPress checkButtons() {
  static unsigned long lastPressTime = 0;
  static ButtonPress lastButton = BTN_NONE;
  
  unsigned long currentTime = millis();
  
  // Verifica debounce
  if (currentTime - lastPressTime < DEBOUNCE_DELAY) {
    return BTN_NONE;
  }
  
  // Lê estado dos botões (LOW = pressionado em INPUT_PULLUP)
  bool upPressed = (digitalRead(BUTTON_UP_PIN) == LOW);
  bool downPressed = (digitalRead(BUTTON_DOWN_PIN) == LOW);
  bool menuPressed = (digitalRead(BUTTON_MENU_PIN) == LOW);
  
  ButtonPress currentButton = BTN_NONE;
  
  if (upPressed) {
    currentButton = BTN_UP;
  } else if (downPressed) {
    currentButton = BTN_DOWN;
  } else if (menuPressed) {
    currentButton = BTN_MENU;
  }
  
  // Só retorna se for um novo pressionamento
  if (currentButton != BTN_NONE && currentButton != lastButton) {
    lastPressTime = currentTime;
    lastButton = currentButton;
    lastButtonPress = currentTime;
    return currentButton;
  }
  
  lastButton = currentButton;
  
  // Timeout para voltar ao menu principal
  if (currentState != STATE_MAIN && currentState != STATE_STARTUP && currentState != STATE_ERROR) {
    if (currentTime - lastButtonPress > MENU_TIMEOUT) {
      currentState = STATE_MAIN;
      lastDisplayState = STATE_STARTUP; // Força redesenho
    }
  }
  
  return BTN_NONE;
}

void updateDisplay() {
  // Só redesenha se o estado mudou
  if (lastDisplayState != currentState) {
    lcd.clear();
    lastDisplayState = currentState;
    lastDisplayedPH = -999.0;
    lastDisplayedTemp = -999.0;
    lastDisplayedIdeal = -999.0;
    lastAlertState = !pHBelowIdeal;
  }
  
  switch (currentState) {
    case STATE_STARTUP:
      lcd.setCursor(0, 1);
      lcd.print("Estabilizando...");
      lcd.setCursor(0, 2);
      lcd.print("Aguarde...");
      break;
      
    case STATE_ERROR:
      lcd.setCursor(0, 0);
      lcd.print("ERRO DE SENSOR!");
      lcd.setCursor(0, 1);
      lcd.print("Verifique conexoes");
      lcd.setCursor(0, 3);
      lcd.print("Reinicie o sistema");
      break;
      
    case STATE_MAIN:
      {
        bool alertStateChanged = (lastAlertState != pHBelowIdeal);
        if (alertStateChanged) {
          lcd.clear();
          lastAlertState = pHBelowIdeal;
          lastDisplayedPH = -999.0;
        }
        
        // Cabeçalho com alerta ou status normal
        lcd.setCursor(0, 0);
        if (pHBelowIdeal) {
          lcd.print("** ALERTA: PH BAIXO **");
        } else {
          // Indicador de atividade
          static unsigned long lastSpinnerUpdate = 0;
          static uint8_t spinnerIndex = 0;
          const char spinner[] = {'|', '/', '-', '\\'};
          
          if (millis() - lastSpinnerUpdate > 500) {
            spinnerIndex = (spinnerIndex + 1) % 4;
            lastSpinnerUpdate = millis();
          }
          
          lcd.print("STATUS ATUAL ");
          lcd.print(spinner[spinnerIndex]);
        }
        
        // Atualiza valores apenas se mudaram significativamente
        float currentAveragePH = getAveragePH();
        bool needsUpdate = (
          fabs(lastDisplayedPH - currentAveragePH) > PH_DISPLAY_THRESHOLD ||
          fabs(lastDisplayedTemp - temperature) > TEMP_DISPLAY_THRESHOLD ||
          fabs(lastDisplayedIdeal - settings.pHIdeal) > PH_DISPLAY_THRESHOLD ||
          alertStateChanged
        );
        
        if (needsUpdate) {
          lcd.setCursor(0, 1);
          lcd.print("PH Medio: ");
          lcd.print(currentAveragePH, 2);
          lcd.print("   ");
          
          lcd.setCursor(0, 2);
          lcd.print("PH Inst.: ");
          lcd.print(currentPH, 2);
          lcd.print("   ");
          
          lcd.setCursor(0, 3);
          lcd.print("T:");
          lcd.print(temperature, 1);
          lcd.print("C");
          lcd.print(" Ideal:");
          lcd.print(settings.pHIdeal, 1);
          lcd.print("   ");
          
          lastDisplayedPH = currentAveragePH;
          lastDisplayedTemp = temperature;
          lastDisplayedIdeal = settings.pHIdeal;
        }
      }
      break;
      
    case STATE_MENU:
      lcd.setCursor(0, 0);
      lcd.print("MENU PRINCIPAL");
      lcd.setCursor(0, 1);
      lcd.print(menuIndex == 0 ? "> Ajustar PH Ideal" : "  Ajustar PH Ideal");
      lcd.setCursor(0, 2);
      lcd.print(menuIndex == 1 ? "> Calibrar Sonda" : "  Calibrar Sonda");
      lcd.setCursor(0, 3);
      lcd.print(menuIndex == 2 ? "> Voltar" : "  Voltar");
      break;
      
    case STATE_ADJUST_PH:
      lcd.setCursor(0, 0);
      lcd.print("Ajustar PH Ideal");
      lcd.setCursor(0, 1);
      lcd.print("Valor: ");
      lcd.print(settings.pHIdeal, 2);
      lcd.print("   ");
      lcd.setCursor(0, 3);
      lcd.print("MENU para salvar");
      break;
      
    case STATE_CALIBRATE_MENU:
      lcd.setCursor(0, 0);
      lcd.print("MENU CALIBRACAO");
      lcd.setCursor(0, 1);
      lcd.print(menuIndex == 0 ? "> 1 Ponto" : "  1 Ponto");
      lcd.setCursor(0, 2);
      lcd.print(menuIndex == 1 ? "> 2 Pontos" : "  2 Pontos");
      lcd.setCursor(0, 3);
      lcd.print(menuIndex == 2 ? "> Voltar" : "  Voltar");
      break;
      
    case STATE_CALIBRATION_CONFIRM:
      lcd.setCursor(0, 0);
      lcd.print("Slope fora padrao");
      lcd.setCursor(0, 1);
      lcd.print("Medido: ");
      lcd.print(tempSlope, 4);
      lcd.setCursor(0, 2);
      lcd.print("Aceitar? > ");
      lcd.print(confirmIndex == 0 ? "Nao" : "Sim");
      break;
  }
}

// ================================================================================================
// == MANIPULADORES DE ESTADO                                                                   ==
// ================================================================================================

void handleStartup() {
  if (millis() - startupTime > STARTUP_DELAY) {
    // Verifica se é a primeira inicialização
    if (EEPROM.read(EEPROM_CONFIG_ADDRESS) != EEPROM_INIT_FLAG) {
      currentState = STATE_CALIBRATE_MENU;
      EEPROM.write(EEPROM_CONFIG_ADDRESS, EEPROM_INIT_FLAG);
    } else {
      currentState = STATE_MAIN;
    }
  }
}

void handleMain(ButtonPress b) {
  static unsigned long menuPressTime = 0;
  static bool menuPressed = false;
  
  if (b == BTN_MENU) {
    if (!menuPressed) {
      menuPressTime = millis();
      menuPressed = true;
    }
    
    // Verifica toque longo (menu técnico)
    if (millis() - menuPressTime > BUTTON_LONG_PRESS) {
      currentState = STATE_CALIBRATE_MENU;
      menuIndex = 0;
      menuPressed = false;
      return;
    }
  } else {
    if (menuPressed) {
      // Toque rápido - menu principal
      if (millis() - menuPressTime <= BUTTON_LONG_PRESS) {
        currentState = STATE_MENU;
        menuIndex = 0;
      }
      menuPressed = false;
    }
  }
}

void handleMenu(ButtonPress b) {
  if (b == BTN_UP) {
    menuIndex = (menuIndex == 0) ? (MENU_ITEMS - 1) : (menuIndex - 1);
    lastButtonPress = millis();
  } else if (b == BTN_DOWN) {
    menuIndex = (menuIndex + 1) % MENU_ITEMS;
    lastButtonPress = millis();
  } else if (b == BTN_MENU) {
    switch (menuIndex) {
      case 0:
        currentState = STATE_ADJUST_PH;
        break;
      case 1:
        currentState = STATE_CALIBRATE_MENU;
        menuIndex = 0;
        break;
      case 2:
        currentState = STATE_MAIN;
        menuIndex = 0;
        break;
    }
    lastButtonPress = millis();
  }
}

void handleAdjustPH(ButtonPress b) {
  if (b == BTN_UP) {
    settings.pHIdeal += PH_ADJUST_STEP;
    lastButtonPress = millis();
  } else if (b == BTN_DOWN) {
    settings.pHIdeal -= PH_ADJUST_STEP;
    lastButtonPress = millis();
  } else if (b == BTN_MENU) {
    // Aplica limites e salva
    if (settings.pHIdeal < PH_MIN_VALID) settings.pHIdeal = PH_MIN_VALID;
    if (settings.pHIdeal > PH_MAX_VALID) settings.pHIdeal = PH_MAX_VALID;
    
    saveSettings();
    currentState = STATE_MAIN;
    lastButtonPress = millis();
  }
}

void handleCalibrateMenu(ButtonPress b) {
  if (b == BTN_UP) {
    menuIndex = (menuIndex == 0) ? (MENU_ITEMS - 1) : (menuIndex - 1);
    lastButtonPress = millis();
  } else if (b == BTN_DOWN) {
    menuIndex = (menuIndex + 1) % MENU_ITEMS;
    lastButtonPress = millis();
  } else if (b == BTN_MENU) {
    switch (menuIndex) {
      case 0:
        currentState = STATE_CALIBRATE_ONE_POINT;
        break;
      case 1:
        currentState = STATE_CALIBRATE_TWO_POINT_FIRST;
        break;
      case 2:
        currentState = STATE_MAIN;
        menuIndex = 0;
        break;
    }
    lastButtonPress = millis();
  }
}

